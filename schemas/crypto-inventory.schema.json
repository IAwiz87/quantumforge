{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quantumforge.dev/schemas/crypto-inventory.schema.json",
  "title": "QuantumForge Vendor-Neutral Cryptographic Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "assets"],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "assets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/crypto_asset"
      }
    }
  },
  "$defs": {
    "crypto_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "asset_id",
        "provider",
        "resource_type",
        "crypto_function",
        "algorithm",
        "classification",
        "owner",
        "environment",
        "source",
        "observed_at",
        "evidence_confidence"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "enum": ["aws", "azure", "gcp", "on_prem", "saas", "application"]
        },
        "resource_type": {
          "type": "string",
          "minLength": 1
        },
        "crypto_function": {
          "enum": [
            "key_management",
            "signing",
            "encryption_at_rest",
            "tls_termination",
            "network_encryption",
            "certificate",
            "certificate_authority",
            "library",
            "protocol",
            "other"
          ]
        },
        "algorithm": {
          "type": "string",
          "minLength": 1
        },
        "protocol": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "enum": ["post_quantum", "hybrid_post_quantum", "classical_only", "symmetric", "unknown"]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "data_flow": {
          "type": "string",
          "minLength": 1
        },
        "key_size_bits": {
          "type": "integer",
          "minimum": 1
        },
        "certificate_not_after": {
          "type": "string",
          "format": "date-time"
        },
        "secrecy_lifetime_years": {
          "type": "number",
          "minimum": 0
        },
        "data_classification": {
          "enum": ["nss", "regulated", "internal", "public"]
        },
        "impact": {
          "enum": ["mission_critical", "business_critical", "operational", "informational"]
        },
        "migration_deadline_months": {
          "type": "number",
          "description": "Months remaining until the migration deadline. Negative values represent an already-overdue asset and are valid input, not an error. Takes precedence over regulatory_category when both are present."
        },
        "regulatory_category": {
          "description": "CNSA 2.0 equipment category used to derive a calendar-anchored migration deadline when migration_deadline_months is not set explicitly.",
          "enum": ["software_firmware_signing", "web_cloud_services", "traditional_networking", "operating_systems", "niche_equipment", "custom_legacy"]
        },
        "dependent_asset_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of other inventoried assets that depend on this one. Used only to advise reviewers that impact may be underrated for high fan-in assets; never overrides the manually assigned impact tier."
        },
        "remediation_effort": {
          "enum": ["low", "medium", "high"]
        },
        "source": {
          "enum": ["terraform_plan", "cloud_api", "cbom", "network_scan", "application_scan", "manual_attestation"]
        },
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "evidence_confidence": {
          "enum": ["high", "medium", "low"]
        },
        "metadata": {
          "type": "object"
        }
      }
    }
  }
}
